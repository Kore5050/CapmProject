@baseUrl = http://localhost:4004/odata/v4/CatalogService

### List all products
GET {{baseUrl}}/Products

### Get product by ID
GET {{baseUrl}}/Products(1)

### Create product (custom handler validates category)
POST {{baseUrl}}/Products
Content-Type: application/json

{
  "title": "Desk Lamp",
  "price": 34.99,
  "stock": 40,
  "category": "Electronics"
}

### Update product
PATCH {{baseUrl}}/Products(1)
Content-Type: application/json

{
  "stock": 160
}

### Delete product
DELETE {{baseUrl}}/Products(6)
