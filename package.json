{
  "name": "CapmProject",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sap/cds": "^9",
    "@sap/cds-fiori": "^2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "mcp": "node server.js",
    "postinstall": "node scripts/ensure-native.js",
    "watch": "node scripts/cds-watch.js"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    },
    "features": {
      "fiori": true
    }
  }
}
